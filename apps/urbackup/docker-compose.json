{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "urbackup",
      "image": "uroni/urbackup-server:latest",
      "isMain": true,
      "privileged": true,
      "restart": "unless-stopped",
      "internalPort": 55414,
      "entrypoint": [
        "/bin/sh",
        "-c",
        "if [ -f /etc/apt/sources.list.d/debian.sources ]; then sed -i 's/Components: main/Components: main contrib/g' /etc/apt/sources.list.d/debian.sources; else echo \"deb http://deb.debian.org/debian trixie contrib\" >> /etc/apt/sources.list; fi && apt-get update && apt-get install -y zfsutils-linux libguestfs-tools && /usr/bin/entrypoint.sh run"
      ],
      "environment": [
        {
          "key": "PUID",
          "value": "0"
        },
        {
          "key": "PGID",
          "value": "0"
        },
        {
          "key": "TZ",
          "value": "Asia/Kolkata"
        },
        {
          "key": "ZFS_IMAGE",
          "value": "mypool/urbackup/images"
        },
        {
          "key": "ZFS_FILES",
          "value": "mypool/urbackup/files"
        }
      ],
      "devices": [
        "/dev/zfs:/dev/zfs"
      ],
      "addPorts": [
        {
          "containerPort": 55413,
          "hostPort": 55413,
          "tcp": true
        },
        {
          "containerPort": 55414,
          "hostPort": 55414,
          "tcp": true
        },
        {
          "containerPort": 55415,
          "hostPort": 55415,
          "tcp": true
        },
        {
          "containerPort": 35623,
          "hostPort": 35623,
          "udp": true
        }
      ],
      "volumes": [
        {
          "hostPath": "/mnt/urbackup/database",
          "containerPath": "/var/urbackup"
        },
        {
          "hostPath": "/mnt/urbackup/settings",
          "containerPath": "/etc/urbackup"
        },
        {
          "hostPath": "/mnt/urbackup",
          "containerPath": "/mnt/urbackup"
        }
      ]
    }
  ]
} 