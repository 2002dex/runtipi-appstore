{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "urbackup",
      "image": "uroni/urbackup-server:2.5.36",
      "isMain": true,
      "internalPort": 55414,
      "environment": [
        {
          "key": "PUID",
          "value": "0"
        },
        {
          "key": "PGID",
          "value": "0"
        },
        {
          "key": "TZ",
          "value": "Asia/Kolkata"
        },
        {
          "key": "ZFS_IMAGE",
          "value": "mnt/urbackup/images"
        },
        {
          "key": "ZFS_FILES",
          "value": "mnt/urbackup/files"
        }
      ],
      "devices": [
        "/dev/zfs:/dev/zfs"
      ],
      "addPorts": [
        {
          "containerPort": 55413,
          "hostPort": 55413,
          "tcp": true
        },
        {
          "containerPort": 55415,
          "hostPort": 55415,
          "tcp": true
        },
        {
          "containerPort": 35623,
          "hostPort": 35623,
          "upd": true
        }
      ],
      "volumes": [
        {
          "type": "bind",
          "hostPath": "/mnt/urbackup",
          "containerPath": "/backups",
          "bind":{
            "propagation": "shared"
          },
          "readOnly": false
        },
        {
            "hostPath": "${APP_DATA_DIR}/data",
            "containerPath": "/var/urbackup"
        }
      ]
    }
  ]
} 