{
  "schemaVersion": 2,
  "services": [
    {
      "name": "vibegateway",
      "image": "dspworks/vibegateway:1.0.3",
      "isMain": true,
      "internalPort": 80,
      "environment": [
        {
          "key": "DB_HOST",
          "value": "mariadb"
        },
        {
          "key": "DB_USER",
          "value": "root"
        },
        {
          "key": "DB_PASSWORD",
          "value": "dspworks"
        },
        {
          "key": "DB_NAME",
          "value": "vshgateway"
        },
        {
          "key": "MQTT_HOST",
          "value": "vibesmarthome.net"
        },
        {
          "key": "MQTT_PORT",
          "value": "8883"
        },
        {
          "key": "MQTT_USER",
          "value": "Vibe_Admin"
        },
        {
          "key": "MQTT_PASSWORD",
          "value": "Vibe@mqtt1256"
        }
      ],
      "devices": [
        "/dev/ttyS6:/dev/ttyS6"
      ],
      "dependsOn": {
        "mariadb": {
          "condition": "service_healthy"
        }
      }
    },
    {
      "name": "mariadb",
      "image": "mariadb:11.4",
      "containerName": "mariadb",
      "environment": [
        {
          "key": "MYSQL_ROOT_PASSWORD",
          "value": "dspworks"
        },
        {
          "key": "MYSQL_ROOT_HOST",
          "value": "%"
        },
        {
          "key": "MYSQL_DATABASE",
          "value": "vshgateway"
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/mariadb_data",
          "containerPath": "/var/lib/mysql",
          "readOnly": false,
          "shared": false,
          "private": false
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/vshgateway.sql",
          "containerPath": "/docker-entrypoint-initdb.d/01-init.sql",
          "readOnly": false,
          "shared": false,
          "private": false
        }
      ],
      "healthCheck": {
        "test": "CMD mariadb-admin ping -u root --password=dspworks",
        "interval": "10s",
        "timeout": "5s",
        "retries": 10,
        "startPeriod": "30s"
      }
    },
    {
      "name": "mqtt",
      "image": "eclipse-mosquitto:2",
      "containerName": "mqtt",
      "ports": [
        {
          "hostPort": 8883,
          "containerPort": 8883
        }
      ],
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/mosquitto/config",
          "containerPath": "/mosquitto/config"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/mosquitto/data",
          "containerPath": "/mosquitto/data"
        },
        {
          "hostPath": "${APP_DATA_DIR}/data/mosquitto/log",
          "containerPath": "/mosquitto/log"
        }
      ]
    }
  ]
}